{
	admin off
	auto_https off

	# Trust X-Forwarded-* headers from upstream proxies in private networks
	# (host reverse proxy, other Docker stacks on the shared network).
	# Without this, Caddy 2.7+ ignores upstream X-Forwarded-Proto and the
	# Go backend can't tell HTTPS apart from HTTP.
	servers {
		trusted_proxies static private_ranges
	}
}

:80 {
	encode zstd gzip

	@api path /api /api/*
	handle @api {
		reverse_proxy api:8080
	}

	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}
}
